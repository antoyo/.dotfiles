#!/bin/bash

host=arch-carbon
dir=projects/ordex
term=alacritty
shell=fish

function open_jailed_dir() {
    $term -e $shell -c "ssh -t $host \"firejail --profile=fish $shell -c 'cd $1 && $shell'\"" &
}

open_jailed_dir $dir
open_jailed_dir $dir
open_jailed_dir $dir
open_jailed_dir "tests/ordex-test"
